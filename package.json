{
  "name": "@omniboard/mcp",
  "version": "0.1.13",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omniboard-mcp": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm lib/index.ts",
    "build": "tsc",
    "watch": "tsc --watch",
    "format:test": "prettier lib/**/*.{ts,json} tooling/**/*.js package.json tsconfig.json",
    "format:write": "prettier lib/**/*.{ts,json} tooling/**/*.js package.json tsconfig.json --write",
    "sync:dist-version": "node tooling/sync-dist-version.js",
    "release": "npm run format:write && npm run build && standard-version -a && npm run sync:dist-version && git push --follow-tags origin main && npm publish --access public",
    "test:runner": "npm run build && node tooling/runner-workspace.integration.js",
    "test:tools": "npm run build && node tooling/mcp-tools.integration.js",
    "test": "npm run test:tools && npm run test:runner"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "xpath": "0.0.32",
    "xmldom": "^0.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.11",
    "@types/xmldom": "^0.1.34",
    "prettier": "^2.8.8",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "description": "Omniboard.dev MCP server that exposes agentic check runs and run progress for local agents.",
  "keywords": [
    "omniboard.dev",
    "mcp",
    "ai",
    "tooling"
  ],
  "license": "MIT",
  "author": "Tomas Trajan <@tomastrajan>",
  "repository": {
    "type": "git",
    "url": "https://github.com/omniboard-dev/mcp.git"
  },
  "bugs": {
    "url": "https://github.com/omniboard-dev/mcp/issues"
  },
  "homepage": "https://github.com/omniboard-dev/mcp#readme"
}
